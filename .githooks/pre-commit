#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
# Pre-commit hook: secret scanner
#
# Blocks commits that contain likely API keys, tokens, or secrets.
# Install: git config core.hooksPath .githooks
# ──────────────────────────────────────────────────────────────

set -euo pipefail

# Patterns that should never appear in committed code
PATTERNS=(
  'RETELL_API_KEY=\S+'
  'ELEVENLABS_API_KEY=\S+'
  'STRIPE_SECRET_KEY=sk_live_\S+'
  'STRIPE_WEBHOOK_SECRET=whsec_\S+'
  'FIREBASE_PRIVATE_KEY=\S+'
  'RESEND_API_KEY=re_\S+'
  'TWILIO_AUTH_TOKEN=\S+'
  'CRON_SECRET=\S+'
  'WRITEUPP_WEBHOOK_SECRET=\S+'
  'N8N_COMMS_WEBHOOK_SECRET=\S+'
  'sk_live_[a-zA-Z0-9]{20,}'
  'sk_test_[a-zA-Z0-9]{20,}'
  'whsec_[a-zA-Z0-9]{20,}'
  're_[a-zA-Z0-9]{20,}'
  '-----BEGIN (RSA |EC )?PRIVATE KEY-----'
)

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -v '\.githooks/' | grep -v '\.env\.example' || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

FOUND=0

for pattern in "${PATTERNS[@]}"; do
  # Iterate files one-by-one so filenames with spaces are preserved as a single
  # arg. `--` marks end-of-options so filenames starting with `-` are not
  # mistaken for flags. `-e "$pattern"` keeps the pattern from being parsed as
  # a flag even when it starts with `-----` (e.g. PRIVATE KEY marker).
  MATCHES=""
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    if grep -lE -e "$pattern" -- "$file" >/dev/null 2>&1; then
      MATCHES="${MATCHES}${MATCHES:+$'\n'}  - ${file}"
    fi
  done <<< "$STAGED"

  if [ -n "$MATCHES" ]; then
    if [ "$FOUND" -eq 0 ]; then
      echo ""
      echo "!! SECRET DETECTED — commit blocked !!"
      echo ""
    fi
    FOUND=1
    echo "  Pattern: $pattern"
    echo "  Files:"
    echo "$MATCHES"
    echo ""
  fi
done

if [ "$FOUND" -ne 0 ]; then
  echo "Remove secrets from staged files before committing."
  echo "If this is a false positive, commit with: git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
