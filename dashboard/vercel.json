{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- .",
  "crons": [
    {
      "path": "/api/pipeline/run",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/intelligence/detect",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/intelligence/digest",
      "schedule": "0 7 * * 0"
    }
  ],
  "routes": [
    {
      "src": "/wp-(admin|login|content|includes)/(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/\\.env(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/phpinfo(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/xmlrpc\\.php",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/api/debug/(.*)",
      "missing": [
        { "type": "header", "key": "authorization" }
      ],
      "mitigate": { "action": "deny" }
    }
  ]
}

