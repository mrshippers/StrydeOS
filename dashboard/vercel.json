{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- .",
  "crons": [
    {
      "path": "/api/pipeline/run",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/intelligence/detect",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/intelligence/digest",
      "schedule": "0 7 * * 0"
    },
    {
      "path": "/api/data-health/check-staleness",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/data-health/cleanup",
      "schedule": "0 3 * * 0"
    }
  ],
  "routes": [
    {
      "src": "/wp-(admin|login|content|includes)/(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/\\.env(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/phpinfo(.*)",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/xmlrpc\\.php",
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/api/debug/(.*)",
      "missing": [
        { "type": "header", "key": "authorization" }
      ],
      "mitigate": { "action": "deny" }
    },
    {
      "src": "/api/auth/session",
      "mitigate": {
        "action": "rate_limit",
        "rateLimit": { "algo": "fixed_window", "window": 60, "limit": 10 }
      }
    },
    {
      "src": "/api/clinic/signup",
      "mitigate": {
        "action": "rate_limit",
        "rateLimit": { "algo": "fixed_window", "window": 60, "limit": 5 }
      }
    },
    {
      "src": "/api/comms/send",
      "mitigate": {
        "action": "rate_limit",
        "rateLimit": { "algo": "fixed_window", "window": 60, "limit": 30 }
      }
    },
    {
      "src": "/api/billing/checkout",
      "mitigate": {
        "action": "rate_limit",
        "rateLimit": { "algo": "fixed_window", "window": 60, "limit": 5 }
      }
    },
    {
      "src": "/api/clinicians/add",
      "mitigate": {
        "action": "rate_limit",
        "rateLimit": { "algo": "fixed_window", "window": 60, "limit": 10 }
      }
    }
  ]
}

