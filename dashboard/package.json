{
  "name": "strydeos-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:mobile": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint src",
    "seed:spires": "node scripts/seed-spires-user.js",
    "seed:production": "npx tsx scripts/seed-spires-production.ts",
    "seed:clinic": "npx tsx scripts/seed-clinic.ts",
    "promote:superadmin": "npx tsx scripts/promote-superadmin.ts",
    "setup:superadmin": "npx tsx scripts/setup-superadmin.ts",
    "fix:joe": "npx tsx scripts/fix-joe-user.ts",
    "test": "vitest run",
    "test:e2e": "E2E_NO_SERVER=1 npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "E2E_NO_SERVER=1 npx playwright test --headed",
    "test:e2e:full": "npm run build && npx playwright test"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.80",
    "@elevenlabs/client": "^0.15.1",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.38",
    "@langchain/langgraph": "^1.2.6",
    "@opentelemetry/api": "^1.9.0",
    "@sentry/nextjs": "^10.43.0",
    "@tailwindcss/postcss": "^4",
    "@vercel/analytics": "^1.4.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.138",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "lucide-react": "^0.474.0",
    "motion": "^12.34.3",
    "next": "^15.1.0",
    "next-intl": "^4.8.3",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "tailwindcss": "^4",
    "twilio": "^5.13.0",
    "typescript": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@next/eslint-plugin-next": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.58.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.1"
  }
}
