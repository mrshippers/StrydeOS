rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isClinicMember(clinicId) {
      return isAuthenticated() && getUserData().clinicId == clinicId;
    }

    function isClinicOwnerOrAdmin(clinicId) {
      let user = getUserData();
      return isAuthenticated()
        && user.clinicId == clinicId
        && user.role in ['owner', 'admin'];
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'superadmin';
    }

    // ─── Users (flat, for auth lookup) ─────────────────────────────────
    // Users may update non-sensitive fields on their own doc only.
    // role / clinicId / clinicianId / status must be set server-side via Admin SDK.
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isSuperAdmin());
      allow update: if isAuthenticated()
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['role', 'clinicId', 'clinicianId', 'status']);
      allow create, delete: if false;
    }

    // ─── User Preferences ──────────────────────────────────────────────
    // Each user can read/write only their own preferences doc.
    match /user_preferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Clinics ───────────────────────────────────────────────────────
    match /clinics/{clinicId} {
      allow read: if isClinicMember(clinicId) || isSuperAdmin();
      allow update: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
      allow create, delete: if isSuperAdmin();

      // Clinicians
      match /clinicians/{clinicianId} {
        allow read: if isClinicMember(clinicId) || isSuperAdmin();
        allow write: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
      }

      // Patients — clinicians can only read their own patients
      match /patients/{patientId} {
        allow read: if isSuperAdmin()
          || isClinicOwnerOrAdmin(clinicId)
          || (isClinicMember(clinicId)
              && resource.data.clinicianId == getUserData().clinicianId);
        allow write: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
      }

      // Appointments
      match /appointments/{appointmentId} {
        allow read: if isClinicMember(clinicId) || isSuperAdmin();
        allow write: if false;
      }

      // Outcome Scores — clinicians can create for their patients
      match /outcome_scores/{scoreId} {
        allow read: if isClinicMember(clinicId) || isSuperAdmin();
        allow create: if isClinicMember(clinicId);
        allow update, delete: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
      }

      // Weekly Metrics — read-only, computed server-side
      match /metrics_weekly/{weekId} {
        allow read: if isClinicMember(clinicId) || isSuperAdmin();
        allow write: if false;
      }

      // Comms Log — owners/admins only
      match /comms_log/{logId} {
        allow read: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
        allow write: if false;
      }

      // Sequence Definitions — owners can toggle active; pipeline seeds (write=false, update allowed for owners)
      match /sequence_definitions/{defId} {
        allow read: if isClinicMember(clinicId) || isSuperAdmin();
        allow update: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
        allow create, delete: if false;
      }

      // Reviews
      match /reviews/{reviewId} {
        allow read: if isClinicMember(clinicId) || isSuperAdmin();
        allow write: if false;
      }

      // Insight Events — Intelligence engine events; readable by clinic members, written by server pipeline
      match /insight_events/{eventId} {
        allow read: if isClinicMember(clinicId) || isSuperAdmin();
        allow update: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
        allow create, delete: if false;
      }

      // Milestones — first-run unlock events; owners/admins can read and update, written by server pipeline
      match /milestones/{milestoneId} {
        allow read: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
        allow update: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
        allow create, delete: if false;
      }

      // Audit Logs — owners/admins can read, write is server-only
      match /audit_logs/{logId} {
        allow read: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
        allow write: if false;
      }

      // Subject Access Requests — owners/admins can read and create, write is server-only for updates
      match /sar_requests/{requestId} {
        allow read: if isClinicOwnerOrAdmin(clinicId) || isSuperAdmin();
        allow create: if isClinicOwnerOrAdmin(clinicId);
        allow update, delete: if false;
      }

      // Call Log — Ava voice agent call records; readable by clinic members, written by server webhook
      match /calls/{callId} {
        allow read: if isClinicMember(clinicId) || isSuperAdmin();
        allow write: if false;
      }

      // Integration Config — server-side only, never exposed to client
      match /integrations_config/{configId} {
        allow read, write: if false;
      }

      // Integration Health — pipeline logs; server-side only, dashboard reads via API
      match /integration_health/{entryId} {
        allow read, write: if false;
      }
    }
  }
}
