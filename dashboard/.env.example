# ─── Firebase Client (public, exposed to browser) ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Firebase Admin (server-side only, NEVER prefix with NEXT_PUBLIC_) ────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Cron Job Auth ────────────────────────────────────────────────────────────
CRON_SECRET=generate_a_random_secret_here

# ─── PMS Integration (WriteUpp) ──────────────────────────────────────────────
# Stored in Firestore integrations_config, not here. These are fallback/dev only.
# WRITEUPP_API_KEY=your_writeupp_key

# ─── Comms Infrastructure ────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+44xxxxxxxxxx

# ─── n8n Webhook URLs ────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_COMMS_WEBHOOK_SECRET=generate_a_random_secret_here

# ─── Voice AI (Receptionist) ─────────────────────────────────────────────────
RETELL_API_KEY=your_retell_key
