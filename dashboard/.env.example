# StrydeOS Dashboard — copy to .env.local and fill in values.
# For production (Vercel) and full live-clinic checklist, see DEPLOY.md.
#
# ─── Firebase Client (public, exposed to browser) ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Firebase Admin (server-side only, NEVER prefix with NEXT_PUBLIC_) ────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Seed script (npm run seed:production) ─────────────────────────────────────
# Required only when running the production seed script. Do not commit real passwords.
# SEED_DEFAULT_PASSWORD=your_seed_password

# ─── Cron Job Auth ────────────────────────────────────────────────────────────
CRON_SECRET=generate_a_random_secret_here
STRYDE_ADMIN_SECRET=generate_a_random_secret_here

# ─── PMS Integration ──────────────────────────────────────────────────────────
# Stored in Firestore integrations_config per clinic, not as env vars.
# These are fallback/dev-only credentials.
# WRITEUPP_API_KEY=your_writeupp_key
# CLINIKO_API_KEY=your_cliniko_key
# HALAXY_API_KEY=your_halaxy_key
# ZANDA_API_KEY=your_zanda_key

# ─── Physitrack ───────────────────────────────────────────────────────────────
# Physitrack → Settings → API Key
PHYSITRACK_API_KEY=your_physitrack_api_key

# ─── WriteUpp Webhook (real-time appointment events) ─────────────────────────
WRITEUPP_WEBHOOK_SECRET=generate_a_random_secret_here

# ─── Google Reviews (Places API) ─────────────────────────────────────────────
# Stored in Firestore integrations_config/google_reviews per clinic.
# Env vars are used as fallback when per-clinic config is not set.
# GOOGLE_PLACES_API_KEY=your_google_places_api_key
# GOOGLE_PLACE_ID=your_google_place_id

# ─── Comms Infrastructure ────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+44xxxxxxxxxx
# Note: Per-clinic numbers are provisioned via /api/ava/provision-number
# and stored in Firestore. TWILIO_PHONE_NUMBER is only used as a
# fallback sender for SMS comms (Pulse module).

# ─── n8n Comms (Railway-hosted n8n) ──────────────────────────────────────────
# Base URL from Railway deployment, e.g. https://your-app.up.railway.app/webhook
N8N_WEBHOOK_BASE_URL=https://your-n8n.up.railway.app/webhook
N8N_COMMS_WEBHOOK_SECRET=generate_a_random_secret_here

# ─── App public URL (used in n8n callbacks + ElevenLabs webhook registration) ─
APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Session Security ───────────────────────────────────────────────────────
# HMAC key for signing session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=generate_a_64_char_hex_secret_here

# ─── Credential Encryption ──────────────────────────────────────────────────
# Master secret for AES-256-GCM encryption of PMS/HEP API keys at rest.
# Per-clinic keys are derived via HMAC-SHA256(secret, "strydeos:credentials:{clinicId}").
# Generate with: openssl rand -hex 32
CREDENTIAL_MASTER_SECRET=generate_a_64_char_hex_secret_here

# ─── WriteUpp API key (server-side) ──────────────────────────────────────────
WRITEUPP_API_KEY=your_writeupp_api_key

# ─── Rate Limiting (Upstash Redis) ──────────────────────────────────────────
# Required for multi-clinic production. In-memory fallback available for
# single-clinic development only.
# From Upstash console → REST API URL
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# From Upstash console → REST API Token
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ─── Voice AI (Receptionist) ─────────────────────────────────────────────────
# ElevenLabs Conversational AI (Ava agent) — elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_key
# Voice ID for Ava — ElevenLabs Dashboard → Voices → copy Voice ID
ELEVENLABS_VOICE_ID=OnKmvBo8ZskQurHsyps5
# Webhook signing secret — ElevenLabs Dashboard → Agent → Webhook → Signing Secret
ELEVENLABS_WEBHOOK_SECRET=your_elevenlabs_webhook_secret
# Shared secret for n8n → /api/bookings/create authentication
AVA_BOOKING_SECRET=generate_a_random_secret_here
# Telegram alerts for escalated calls (optional) — t.me/BotFather → create bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── CSV Inbound Email (ingest webhook auth) ─────────────────────────────────
CSV_INBOUND_SECRET=generate_a_random_secret_here

# ─── LangGraph / Anthropic (Ava intent classification) ───────────────────────
# Required for LangGraph router node in lib/ava/graph.ts.
# Without this, Ava falls back to keyword-based intent matching.
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Ava Python Engine (optional booking proxy) ──────────────────────────────
# When set, /api/ava/tools forwards tool calls to the Python booking engine
# for richer slot negotiation. Falls back to TS adapters on any failure.
# AVA_ENGINE_URL=https://ava-engine.your-host.com

# ─── Google Reviews (Places API) ─────────────────────────────────────────────
# Used as fallback when per-clinic config is not set in Firestore.
# GOOGLE_PLACES_API_KEY=your_google_places_api_key
# GOOGLE_PLACE_ID=your_google_place_id

# ─── App Environment ─────────────────────────────────────────────────────────
# Set to "staging" to show staging banner in the UI
# NEXT_PUBLIC_APP_ENV=staging
# Set to "true" to enable ElevenLabs call log features
# NEXT_PUBLIC_ELEVENLABS_CONFIGURED=true
# Runtime environment label (used by Sentry instrumentation)
# NEXT_PUBLIC_ENV=production

# ─── Sentry ──────────────────────────────────────────────────────────────────
# Only required for source map uploads (CI/CD build)
# SENTRY_ORG=your_sentry_org
# SENTRY_PROJECT=your_sentry_project
# SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ─── Stripe Billing ───────────────────────────────────────────────────────────
# Publishable key (client-side): Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Secret key: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret: Stripe Dashboard → Webhooks, or "stripe listen" for local dev
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — run from dashboard: npx tsx scripts/setup-stripe-products.ts (then paste output here)
# Format: STRIPE_PRICE_{PRODUCT}_{TIER}_{INTERVAL}. Product = INTELLIGENCE | PULSE | AVA | FULLSTACK; AVA_SETUP = one-time.
STRIPE_PRICE_INTELLIGENCE_SOLO_MONTH=price_...
STRIPE_PRICE_INTELLIGENCE_SOLO_YEAR=price_...
STRIPE_PRICE_INTELLIGENCE_STUDIO_MONTH=price_...
STRIPE_PRICE_INTELLIGENCE_STUDIO_YEAR=price_...
STRIPE_PRICE_INTELLIGENCE_CLINIC_MONTH=price_...
STRIPE_PRICE_INTELLIGENCE_CLINIC_YEAR=price_...
STRIPE_PRICE_AVA_SOLO_MONTH=price_...
STRIPE_PRICE_AVA_SOLO_YEAR=price_...
STRIPE_PRICE_AVA_STUDIO_MONTH=price_...
STRIPE_PRICE_AVA_STUDIO_YEAR=price_...
STRIPE_PRICE_AVA_CLINIC_MONTH=price_...
STRIPE_PRICE_AVA_CLINIC_YEAR=price_...
STRIPE_PRICE_PULSE_SOLO_MONTH=price_...
STRIPE_PRICE_PULSE_SOLO_YEAR=price_...
STRIPE_PRICE_PULSE_STUDIO_MONTH=price_...
STRIPE_PRICE_PULSE_STUDIO_YEAR=price_...
STRIPE_PRICE_PULSE_CLINIC_MONTH=price_...
STRIPE_PRICE_PULSE_CLINIC_YEAR=price_...
STRIPE_PRICE_FULLSTACK_SOLO_MONTH=price_...
STRIPE_PRICE_FULLSTACK_SOLO_YEAR=price_...
STRIPE_PRICE_FULLSTACK_STUDIO_MONTH=price_...
STRIPE_PRICE_FULLSTACK_STUDIO_YEAR=price_...
STRIPE_PRICE_FULLSTACK_CLINIC_MONTH=price_...
STRIPE_PRICE_FULLSTACK_CLINIC_YEAR=price_...
STRIPE_PRICE_AVA_SETUP=price_...

# Extra Clinician Seat (per-seat add-on, £49/mo or £470.40/yr)
STRIPE_PRICE_EXTRA_SEAT_MONTH=price_...
STRIPE_PRICE_EXTRA_SEAT_YEAR=price_...

# Stripe Customer Portal — https://dashboard.stripe.com/settings/billing/portal
# Enable "Update subscriptions" + "Cancel subscriptions" for self-serve module management.
