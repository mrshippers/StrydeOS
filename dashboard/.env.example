# StrydeOS Dashboard — copy to .env.local and fill in values.
# For production (Vercel) and full live-clinic checklist, see DEPLOY.md.
#
# ─── Firebase Client (public, exposed to browser) ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Firebase Admin (server-side only, NEVER prefix with NEXT_PUBLIC_) ────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Seed script (npm run seed:production) ─────────────────────────────────────
# Required only when running the production seed script. Do not commit real passwords.
# SEED_DEFAULT_PASSWORD=your_seed_password

# ─── Cron Job Auth ────────────────────────────────────────────────────────────
CRON_SECRET=generate_a_random_secret_here

# ─── PMS Integration (WriteUpp) ──────────────────────────────────────────────
# Stored in Firestore integrations_config, not here. These are fallback/dev only.
# WRITEUPP_API_KEY=your_writeupp_key

# ─── Physitrack ───────────────────────────────────────────────────────────────
# Physitrack → Settings → API Key
PHYSITRACK_API_KEY=your_physitrack_api_key

# ─── WriteUpp Webhook (real-time appointment events) ─────────────────────────
WRITEUPP_WEBHOOK_SECRET=generate_a_random_secret_here

# ─── Google Reviews (Places API) ─────────────────────────────────────────────
# Stored in Firestore integrations_config/google_reviews per clinic.
# GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ─── Comms Infrastructure ────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+44xxxxxxxxxx

# ─── n8n Comms (Railway-hosted n8n) ──────────────────────────────────────────
# Base URL from Railway deployment, e.g. https://your-app.up.railway.app/webhook
N8N_WEBHOOK_BASE_URL=https://your-n8n.up.railway.app/webhook
N8N_COMMS_WEBHOOK_SECRET=generate_a_random_secret_here

# ─── App public URL (used in n8n callback payloads) ──────────────────────────
APP_URL=https://your-app.vercel.app

# ─── Voice AI (Receptionist) ─────────────────────────────────────────────────
RETELL_API_KEY=your_retell_key

# ─── Stripe Billing ───────────────────────────────────────────────────────────
# Secret key: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret: Stripe Dashboard → Webhooks, or "stripe listen" for local dev
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — run from dashboard: npx tsx scripts/setup-stripe-products.ts (then paste output here)
# Format: STRIPE_PRICE_{PRODUCT}_{TIER}_{INTERVAL}. Product = INTELLIGENCE | PULSE | AVA | FULLSTACK; AVA_SETUP = one-time.
STRIPE_PRICE_INTELLIGENCE_SOLO_MONTH=price_...
STRIPE_PRICE_INTELLIGENCE_SOLO_YEAR=price_...
STRIPE_PRICE_INTELLIGENCE_STUDIO_MONTH=price_...
STRIPE_PRICE_INTELLIGENCE_STUDIO_YEAR=price_...
STRIPE_PRICE_INTELLIGENCE_CLINIC_MONTH=price_...
STRIPE_PRICE_INTELLIGENCE_CLINIC_YEAR=price_...
STRIPE_PRICE_AVA_SOLO_MONTH=price_...
STRIPE_PRICE_AVA_SOLO_YEAR=price_...
STRIPE_PRICE_AVA_STUDIO_MONTH=price_...
STRIPE_PRICE_AVA_STUDIO_YEAR=price_...
STRIPE_PRICE_AVA_CLINIC_MONTH=price_...
STRIPE_PRICE_AVA_CLINIC_YEAR=price_...
STRIPE_PRICE_PULSE_SOLO_MONTH=price_...
STRIPE_PRICE_PULSE_SOLO_YEAR=price_...
STRIPE_PRICE_PULSE_STUDIO_MONTH=price_...
STRIPE_PRICE_PULSE_STUDIO_YEAR=price_...
STRIPE_PRICE_PULSE_CLINIC_MONTH=price_...
STRIPE_PRICE_PULSE_CLINIC_YEAR=price_...
STRIPE_PRICE_FULLSTACK_SOLO_MONTH=price_...
STRIPE_PRICE_FULLSTACK_SOLO_YEAR=price_...
STRIPE_PRICE_FULLSTACK_STUDIO_MONTH=price_...
STRIPE_PRICE_FULLSTACK_STUDIO_YEAR=price_...
STRIPE_PRICE_FULLSTACK_CLINIC_MONTH=price_...
STRIPE_PRICE_FULLSTACK_CLINIC_YEAR=price_...
STRIPE_PRICE_AVA_SETUP=price_...

# Stripe Customer Portal — https://dashboard.stripe.com/settings/billing/portal
# Enable "Update subscriptions" + "Cancel subscriptions" for self-serve module management.
